<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:adonisUi="clr-namespace:AdonisUI;assembly=AdonisUI">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/AdonisUI;component/ColorSchemes/Light.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Themes/SharedAssets.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Resources/vendor/asus/rog/rog-logo-alt.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Resources/vendor/asus/proart/proart-logo-alt.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Resources/vendor/gskill/gskill-logo-alt.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Resources/vendor/biwin/biwin-logo-alt.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Thickness x:Key="WindowBorderThickness">1</Thickness>

    <SolidColorBrush x:Key="TextColor" Color="{StaticResource {x:Static adonisUi:Colors.ForegroundColor}}" />
    <SolidColorBrush x:Key="AccentTextColor" Color="#004b84" />
    <SolidColorBrush x:Key="SeparatorColor" Color="#e5e5e5" />
    <SolidColorBrush x:Key="PanelBackground" Color="#f3f3f3" />
    <SolidColorBrush x:Key="BottomPanelBackground" Color="#f3f3f3" />
    <SolidColorBrush x:Key="MainMenuPanelBackground" Color="#f3f3f3" />
    <SolidColorBrush x:Key="MenuItemBackground" Color="#f3f3f3" />
    <SolidColorBrush x:Key="ContentBackground" Color="#f7f7f7" />
    <SolidColorBrush x:Key="SuccessBackground" Color="#d4edda" />
    <SolidColorBrush x:Key="DisabledColor" Color="#a0a0a0" />
    <SolidColorBrush x:Key="WindowBorderColor" Color="#c4c4c4" />

    <!-- Window background color -->
    <Color x:Key="{x:Static adonisUi:Colors.Layer0BackgroundColor}">#f3f3f3</Color>
    <!-- Window border and titlebar color -->
    <Color x:Key="{x:Static adonisUi:Colors.Layer0BorderColor}">#f3f3f3</Color>
    <!-- Window text color -->
    <Color x:Key="{x:Static adonisUi:Colors.ForegroundColor}">#212529</Color>

    <!-- logo -->
    <SolidColorBrush x:Key="LogoColor" Color="{StaticResource {x:Static adonisUi:Colors.ForegroundColor}}" />
    <SolidColorBrush x:Key="LogoColorAlt" Color="{StaticResource {x:Static adonisUi:Colors.ForegroundColor}}" />
</ResourceDictionary>