<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:adonisUi="clr-namespace:AdonisUI;assembly=AdonisUI">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/AdonisUI;component/ColorSchemes/Dark.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Themes/SharedAssets.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- Text color -->
    <Color x:Key="{x:Static adonisUi:Colors.ForegroundColor}">#C9CDD2</Color>
    <Color x:Key="SecondaryTextColor">#9A9FA7</Color>

    <!-- Window title background -->
    <Color x:Key="{x:Static adonisUi:Colors.Layer0BorderColor}">#0B0B0C</Color>
    <!-- Window background -->
    <Color x:Key="{x:Static adonisUi:Colors.Layer0BackgroundColor}">#0B0B0C</Color>

    <!-- Deep borders -->
    <Color x:Key="{x:Static adonisUi:Colors.Layer3BorderColor}">#050506</Color>

    <!-- Accent (cool neutral blue-gray for contrast on black) -->
    <Color x:Key="{x:Static adonisUi:Colors.AccentColor}">#9FB3C8</Color>
    <Color x:Key="{x:Static adonisUi:Colors.AccentForegroundColor}">#0B0B0C</Color>

    <!-- Accent hover -->
    <Color x:Key="{x:Static adonisUi:Colors.AccentHighlightColor}">#B3C4D6</Color>
    <!-- Accent active -->
    <Color x:Key="{x:Static adonisUi:Colors.AccentInteractionColor}">#C4D2E0</Color>
    <Color x:Key="{x:Static adonisUi:Colors.AccentInteractionBorderColor}">#C4D2E0</Color>
    <Color x:Key="{x:Static adonisUi:Colors.AccentIntenseHighlightBorderColor}">#C4D2E0</Color>

    <!-- Layer 1 (menus, dropdowns) -->
    <Color x:Key="{x:Static adonisUi:Colors.Layer1BackgroundColor}">#141416</Color>
    <Color x:Key="{x:Static adonisUi:Colors.Layer1BorderColor}">#141416</Color>

    <!-- Hover -->
    <Color x:Key="{x:Static adonisUi:Colors.Layer1HighlightColor}">#1C1D21</Color>
    <Color x:Key="{x:Static adonisUi:Colors.Layer1HighlightBorderColor}">#26282E</Color>

    <!-- Buttons hover -->
    <Color x:Key="{x:Static adonisUi:Colors.WindowButtonHighlightColor}">#1C1D21</Color>

    <!-- Layer 2 -->
    <Color x:Key="{x:Static adonisUi:Colors.Layer2HighlightColor}">#1C1D21</Color>
    <Color x:Key="{x:Static adonisUi:Colors.Layer2HighlightBorderColor}">#1C1D21</Color>

    <CornerRadius x:Key="{x:Static adonisUi:Dimensions.CornerRadius}">2</CornerRadius>

    <SolidColorBrush x:Key="AccentTextColor"
                     Color="{StaticResource {x:Static adonisUi:Colors.AccentColor}}" />

    <!-- Panels -->
    <SolidColorBrush x:Key="PanelBackground"
                     Color="{StaticResource {x:Static adonisUi:Colors.Layer0BackgroundColor}}" />
    <SolidColorBrush x:Key="BottomPanelBackground"
                     Color="{StaticResource {x:Static adonisUi:Colors.Layer0BackgroundColor}}" />
    <SolidColorBrush x:Key="MainMenuPanelBackground"
                     Color="{StaticResource {x:Static adonisUi:Colors.Layer0BackgroundColor}}" />
    <SolidColorBrush x:Key="MenuItemBackground"
                     Color="{StaticResource {x:Static adonisUi:Colors.Layer0BackgroundColor}}" />

    <SolidColorBrush x:Key="TextColor"
                     Color="{StaticResource {x:Static adonisUi:Colors.ForegroundColor}}" />
    <SolidColorBrush x:Key="SecondaryTextBrush"
                     Color="{StaticResource SecondaryTextColor}" />
    <SolidColorBrush x:Key="SeparatorColor"
                     Color="{StaticResource {x:Static adonisUi:Colors.Layer3BorderColor}}" />

    <!-- Status / misc -->
    <SolidColorBrush x:Key="SuccessBackground" Color="#2F6E4F" />
    <SolidColorBrush x:Key="DisabledColor" Color="#6A6F78" />
    <SolidColorBrush x:Key="WindowBorderColor"
                     Color="{StaticResource {x:Static adonisUi:Colors.Layer3BorderColor}}" />

    <!-- Logo brushes (important for your shared assets setup) -->
    <SolidColorBrush x:Key="LogoColor"
                     Color="{StaticResource {x:Static adonisUi:Colors.ForegroundColor}}" />
    <SolidColorBrush x:Key="LogoColorAlt"
                     Color="{StaticResource {x:Static adonisUi:Colors.ForegroundColor}}" />

</ResourceDictionary>