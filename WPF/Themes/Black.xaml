<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:adonisUi="clr-namespace:AdonisUI;assembly=AdonisUI">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/AdonisUI;component/ColorSchemes/Dark.xaml" />
        <ResourceDictionary Source="pack://application:,,,/Themes/SharedAssets.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Thickness x:Key="WindowBorderThickness">1</Thickness>
    <CornerRadius x:Key="{x:Static adonisUi:Dimensions.CornerRadius}">2</CornerRadius>
    
    <!-- Text color -->
    <Color x:Key="{x:Static adonisUi:Colors.ForegroundColor}">#C9CDD2</Color>
    <Color x:Key="SecondaryTextColor">#9A9FA7</Color>

    <!-- Window title background -->
    <Color x:Key="{x:Static adonisUi:Colors.Layer0BorderColor}">#000000</Color>
    <!-- Window background -->
    <Color x:Key="{x:Static adonisUi:Colors.Layer0BackgroundColor}">#000000</Color>

    <!-- Deep borders -->
    <Color x:Key="{x:Static adonisUi:Colors.Layer3BorderColor}">#0A0A0A</Color>

    <!-- Accent (cool neutral blue-gray for contrast on black) -->
    <Color x:Key="{x:Static adonisUi:Colors.AccentColor}">#AFC6DD</Color>
    <Color x:Key="{x:Static adonisUi:Colors.AccentForegroundColor}">#000000</Color>

    <!-- Accent hover -->
    <Color x:Key="{x:Static adonisUi:Colors.AccentHighlightColor}">#C2D6EA</Color>
    <!-- Accent active -->
    <Color x:Key="{x:Static adonisUi:Colors.AccentInteractionColor}">#D3E2F0</Color>
    <Color x:Key="{x:Static adonisUi:Colors.AccentInteractionBorderColor}">#D3E2F0</Color>
    <Color x:Key="{x:Static adonisUi:Colors.AccentIntenseHighlightBorderColor}">#D3E2F0</Color>

    <!-- Layer 1 (menus, dropdowns) -->
    <Color x:Key="{x:Static adonisUi:Colors.Layer1BackgroundColor}">#000000</Color>
    <Color x:Key="{x:Static adonisUi:Colors.Layer1BorderColor}">#0D0D0D</Color>

    <!-- Hover -->
    <Color x:Key="{x:Static adonisUi:Colors.Layer1HighlightColor}">#141414</Color>
    <Color x:Key="{x:Static adonisUi:Colors.Layer1HighlightBorderColor}">#1C1C1C</Color>

    <!-- Buttons hover -->
    <Color x:Key="{x:Static adonisUi:Colors.WindowButtonHighlightColor}">#141414</Color>

    <!-- Layer 2 -->
    <Color x:Key="{x:Static adonisUi:Colors.Layer2HighlightColor}">#141414</Color>
    <Color x:Key="{x:Static adonisUi:Colors.Layer2HighlightBorderColor}">#141414</Color>

    <SolidColorBrush x:Key="AccentTextColor"
                     Color="{StaticResource {x:Static adonisUi:Colors.AccentColor}}" />

    <!-- Panels -->
    <SolidColorBrush x:Key="PanelBackground"
                     Color="{StaticResource {x:Static adonisUi:Colors.Layer0BackgroundColor}}" />
    <SolidColorBrush x:Key="BottomPanelBackground"
                     Color="{StaticResource {x:Static adonisUi:Colors.Layer0BackgroundColor}}" />
    <SolidColorBrush x:Key="MainMenuPanelBackground"
                     Color="{StaticResource {x:Static adonisUi:Colors.Layer0BackgroundColor}}" />
    <SolidColorBrush x:Key="MenuItemBackground"
                     Color="{StaticResource {x:Static adonisUi:Colors.Layer0BackgroundColor}}" />

    <SolidColorBrush x:Key="TextColor"
                     Color="{StaticResource {x:Static adonisUi:Colors.ForegroundColor}}" />
    <SolidColorBrush x:Key="SecondaryTextBrush"
                     Color="{StaticResource SecondaryTextColor}" />
    <SolidColorBrush x:Key="SeparatorColor"
                     Color="{StaticResource {x:Static adonisUi:Colors.Layer3BorderColor}}" />

    <!-- Status / misc -->
    <SolidColorBrush x:Key="SuccessBackground" Color="#2F6E4F" />
    <SolidColorBrush x:Key="DisabledColor" Color="#6A6F78" />
    <SolidColorBrush x:Key="WindowBorderColor"
                     Color="{StaticResource {x:Static adonisUi:Colors.Layer3BorderColor}}" />

    <!-- Logo brushes (important for your shared assets setup) -->
    <SolidColorBrush x:Key="LogoColor"
                     Color="{StaticResource {x:Static adonisUi:Colors.ForegroundColor}}" />
    <SolidColorBrush x:Key="LogoColorAlt"
                     Color="{StaticResource {x:Static adonisUi:Colors.ForegroundColor}}" />

    <Style x:Key="WindowStyles" TargetType="{x:Type Window}">
        <Setter Property="BorderThickness" Value="{StaticResource WindowBorderThickness}" />
        <Setter Property="BorderBrush" Value="{StaticResource WindowBorderColor}" />
    </Style>

</ResourceDictionary>