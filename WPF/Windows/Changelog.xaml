<local:ThemedAdonisWindow
    xmlns:local="clr-namespace:ZenTimings"
    xmlns:adonisControls="clr-namespace:AdonisUI.Controls;assembly=AdonisUI"
    x:Class="ZenTimings.Windows.Changelog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
    xmlns:converters="clr-namespace:ZenTimings.Converters"
    mc:Ignorable="d"
    Style="{DynamicResource WindowStyles}"
    Title="What's New"
    Height="580"
    Width="454"
    UseLayoutRounding="True"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterScreen"
    Topmost="True" Icon="/ZenTimings;component/Resources/new-icon/16.png"
    SizeToContent="WidthAndHeight">

    <Window.Resources>
        <converters:DDR5ToVisConverter x:Key="DDR5ToBool" />
    </Window.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto" />
            </Grid.RowDefinitions>

            <StackPanel Orientation="Vertical" Margin="15,15,5,15" Grid.ColumnSpan="6" Grid.Row="0" Width="424">
                <!-- TextBlock Text="Changelog" FontSize="14" FontWeight="Bold" Style="{DynamicResource ValueStyles}" Height="auto" HorizontalAlignment="Left" /-->
                <TextBlock Text="v1.39" FontSize="13" Style="{DynamicResource ValueStyles}" Height="auto" HorizontalAlignment="Left" Margin="0" />

                <TextBlock Text="" />
                <TextBlock Text=" - Fixed a bug in smbus driver which was leading to conflict with hwinfo" TextWrapping="WrapWithOverflow" />
                <TextBlock Text=" - Detach Telemetry window from main application and update layout" TextWrapping="WrapWithOverflow" />
                <TextBlock Text=" - Hynix IC revision parser should not longer display incorrect 'O-die'" TextWrapping="WrapWithOverflow" />
            </StackPanel>
            <Border Padding="4 10" Grid.ColumnSpan="6" Grid.Row="2">
                <Button x:Name="Changelog_Close" Content="OK" Width="80" IsCancel="True" />
            </Border>
        </Grid>
    </ScrollViewer>
</local:ThemedAdonisWindow>
