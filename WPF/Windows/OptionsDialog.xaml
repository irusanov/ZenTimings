<local:ThemedAdonisWindow
    xmlns:local="clr-namespace:ZenTimings"
    x:Class="ZenTimings.Windows.OptionsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:adonisControls="clr-namespace:AdonisUI.Controls;assembly=AdonisUI"
    xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
    xmlns:adonisUi="clr-namespace:AdonisUI;assembly=AdonisUI"
    adonisExtensions:CursorSpotlightExtension.RelativeSpotlightSize="0"
    mc:Ignorable="d"
    x:Name="OptionsWindow"
    Title="Options"
    Height="629"
    Width="400"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner"
    Icon="/ZenTimings;component/Resources/new-icon/16.png"
    SizeToContent="WidthAndHeight"
    ShowInTaskbar="False"
    BorderThickness="1"
    UseLayoutRounding="True"
    Style="{DynamicResource WindowStyles}"
    Closing="OptionsWindow_Closing">

    <StackPanel x:Name="OptionWindowContent">
        <Popup
            x:Name="OptionsPopup"
            Panel.ZIndex="100"
            PlacementTarget="{Binding ElementName=OptionWindowContent}"
            VerticalAlignment="Center"
            Placement="Relative"
            HorizontalAlignment="Center"
            VerticalOffset="0"
            AllowsTransparency="True"
            Opacity="0.8"
            PopupAnimation="Fade"
            ClipToBounds="True"
            StaysOpen="False"
            ScrollViewer.VerticalScrollBarVisibility="Disabled"
            MouseDown="OptionsPopup_MouseDown">
            <TextBlock
                Name="OptionsPopupText"
                Background="{DynamicResource SuccessBackground}"
                Padding="10" Opacity="0.95">
                Settings Saved.
            </TextBlock>
        </Popup>

        <!--TabControl
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Padding="0"
            Background="{DynamicResource PanelBackground}"
            BorderThickness="0,1"
            ClipToBounds="True"
            SnapsToDevicePixels="True"
            MinHeight="190"
            MinWidth="310"
            ScrollViewer.CanContentScroll="True"
            BorderBrush="{DynamicResource SeparatorColor}"
            Template="{DynamicResource TabControlControlTemplate}">
            <TabItem
                Header="General"
                Background="{DynamicResource PanelBackground}"
                BorderThickness="0,1,1,1"
                BorderBrush="{DynamicResource SeparatorColor}"-->

        <StackPanel
            Orientation="Vertical"
            Margin="6">
            <TextBlock Text="General" Padding="6 6" />
            <Border Style="{DynamicResource Separator}" />
            <Grid Margin="16 8 8 8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="78" />
                    <ColumnDefinition Width="78" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>

                <ToggleButton
                    x:Name="checkBoxAdvancedMode"
                    Grid.Column="0"
                    Grid.Row="0"
                    Grid.ColumnSpan="3"
                    Margin="0 5 5 5"
                    Style="{DynamicResource {x:Static adonisUi:Styles.ToggleSwitch}}"
                    Content="Advanced mode"
                    Click="CheckBoxAdvancedMode_Click" />

                <ToggleButton
                    x:Name="checkBoxAutoRefresh"
                    Grid.Column="0"
                    Grid.Row="1"
                    Content="Auto refresh"
                    Margin="0 5 5 5"
                    Style="{DynamicResource {x:Static adonisUi:Styles.ToggleSwitch}}"
                    Click="CheckBoxAutoRefresh_Click" />

                <TextBox
                    x:Name="numericUpDownRefreshInterval"
                    Grid.Column="1"
                    Grid.Row="1"
                    Margin="5 0 5 0" />

                <Label
                    x:Name="msText"
                    Grid.Column="2"
                    Grid.Row="1"
                    Content="ms"
                    VerticalAlignment="Center"
                    Padding="5 0" FontWeight="Normal" />

                <ToggleButton
                    x:Name="checkBoxCheckUpdate"
                    Grid.Column="0"
                    Grid.Row="2"
                    Grid.ColumnSpan="3"
                    Margin="0 5 5 5"
                    Style="{DynamicResource {x:Static adonisUi:Styles.ToggleSwitch}}"
                        Content="Check for updates" />

                <ToggleButton
                    x:Name="checkBoxSingleInstance"
                    Grid.Column="0"
                    Grid.Row="3"
                    Grid.ColumnSpan="3"
                    Margin="0 5 5 5"
                    Style="{DynamicResource {x:Static adonisUi:Styles.ToggleSwitch}}"
                    Content="Single instance" />

                <ToggleButton
                     x:Name="checkBoxMinimizeToTray"
                     Content="Minimize to tray"
                     Grid.Row="04"
                     Grid.Column="0"
                     Grid.ColumnSpan="3"
                     Margin="0 5 5 5"
                     Style="{DynamicResource {x:Static adonisUi:Styles.ToggleSwitch}}" />

                <TextBlock
                    Grid.Column="0"
                    Grid.Row="5"
                    Margin="0 5 5 5"
                    Text="Theme" VerticalAlignment="Center" />
                <ComboBox
                    x:Name="comboBoxTheme"
                    Grid.ColumnSpan="2"
                    Grid.Column="1"
                    Grid.Row="5"
                    HorizontalAlignment="Left"
                    Margin="5,0,0,0"
                    VerticalAlignment="Top"
                    SelectionChanged="ComboBoxTheme_SelectionChanged"
                    Width="151"
                 >
                    <ComboBoxItem Content="Light" />
                    <ComboBoxItem Content="Dark" />
                    <ComboBoxItem Content="Dark Mint" />
                    <ComboBoxItem Content="Dark Mint Gradient" />
                    <ComboBoxItem Content="Asus ROG" />
                    <ComboBoxItem Content="Dracula" />
                    <ComboBoxItem Content="Retro Wave" />
                    <ComboBoxItem Content="Burnt Orange" />
                    <!--ComboBoxItem Content="Charcoal" /-->
                    <ComboBoxItem Content="Black" />
                </ComboBox>

                <TextBlock
                    Grid.Column="0"
                    Grid.Row="6"
                    Margin="0 5 5 5"
                    Text="Impedance table source" VerticalAlignment="Center" />

                <ComboBox
                    x:Name="comboBoxImpedanceSource"
                    Grid.ColumnSpan="2"
                    Grid.Column="1"
                    Grid.Row="6"
                    HorizontalAlignment="Left"
                    Margin="5,0,0,0"
                    VerticalAlignment="Top"
                    Width="151"
                >
                    <ComboBoxItem Content="Legacy" />
                    <ComboBoxItem Content="Extended (experimental)" />
                </ComboBox>
            </Grid>
        </StackPanel>

        <StackPanel
            Orientation="Vertical"
            Margin="6">
            <TextBlock  Text="Window" Padding="6 6" />
            <Border Style="{DynamicResource Separator}" />
            <Grid Margin="16 8 8 8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="78" />
                    <ColumnDefinition Width="78" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>

                <ToggleButton
                     x:Name="checkBoxSavePosition"
                     Grid.Column="0"
                     Grid.Row="0"
                     Grid.ColumnSpan="3"
                     Margin="0 5 5 5"
                     Style="{DynamicResource {x:Static adonisUi:Styles.ToggleSwitch}}"
                     Content="Save position on app close" />

                <!--ToggleButton
                     x:Name="checkBoxDisableRoundedCorners"
                     Grid.Column="0"
                     Grid.Row="1"
                     Grid.ColumnSpan="3"
                     Margin="0 5 5 5"
                     Style="{DynamicResource {x:Static adonisUi:Styles.ToggleSwitch}}"
                     Content="Disable rounded corners (Windows 11 only)" /-->

                <TextBlock
                    Grid.Column="0"
                    Grid.Row="1"
                    Margin="0 5 5 5"
                    Text="Corner radius (Win 11)" VerticalAlignment="Center" />
                <ComboBox
                    x:Name="comboBoxCornerRadius"
                    Grid.ColumnSpan="2"
                    Grid.Column="1"
                    Grid.Row="1"
                    HorizontalAlignment="Left"
                    Margin="5,0,0,0"
                    VerticalAlignment="Top"
                    Width="151"
                 >
                    <ComboBoxItem Content="Auto" />
                    <ComboBoxItem Content="No Radius" />
                    <ComboBoxItem Content="Default Radius" />
                    <ComboBoxItem Content="Small Radius" />
                </ComboBox>
            </Grid>
        </StackPanel>

        <StackPanel
            Orientation="Vertical"
            Margin="6">
            <TextBlock Text="Screenshot" Padding="6 6" />
            <Border Style="{DynamicResource Separator}" />
            <Grid Margin="16 8 8 8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="78" />
                    <ColumnDefinition Width="78" />
                    <ColumnDefinition Width="auto" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="auto" />
                    <RowDefinition Height="auto" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Grid.Row="0"
                    Margin="0 5 5 5"
                    Text="Mode" VerticalAlignment="Center" />
                
                <ComboBox
                    x:Name="comboBoxScreenshot"
                    Grid.ColumnSpan="2"
                    Grid.Column="1"
                    Grid.Row="0"
                    HorizontalAlignment="Left"
                    Margin="5,0,0,0"
                    VerticalAlignment="Top"
                    Width="151"
                 >
                    <ComboBoxItem Content="App Window" />
                    <ComboBoxItem Content="Desktop" />
                </ComboBox>

                <TextBlock
                    x:Name="screenshotPath"
                    Grid.Column="0"
                    Grid.Row="1"
                    Margin="0 5 5 5"
                    Text="Location" VerticalAlignment="Center" />

                <TextBox
                    x:Name="textBoxScreenshotPath"
                    Grid.Column="1"
                    Grid.Row="1"
                    Grid.ColumnSpan="2"
                    Margin="3,0,0,0"
                    Width="151"
                    IsReadOnly="True"
                    VerticalAlignment="Top" />

                <Button
                    x:Name="buttonBrowseScreenshotPath"
                    Grid.Column="3"
                    Grid.Row="1"
                    Content="Browse..."
                    Margin="5,0,0,0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top" Click="ButtonBrowseScreenshotPath_Click"/>
            </Grid>
        </StackPanel>

        <!--/TabItem>
            <TabItem
                Header="Sensors"
                Background="{DynamicResource PanelBackground}"
                BorderThickness="0,1,1,1"
                BorderBrush="{DynamicResource SeparatorColor}">
                <Grid Margin="8,12,8,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto" />
                        <ColumnDefinition Width="78" />
                        <ColumnDefinition Width="78" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto" />
                        <RowDefinition Height="auto" />
                    </Grid.RowDefinitions>

                    <Label
                        x:Name="vdimmSourceLabel"
                        Grid.Column="0"
                        Grid.Row="0"
                        Content="VDIMM Source"
                        VerticalAlignment="Center"
                        Padding="5 0" FontWeight="Normal" />

                    <ComboBox
                        x:Name="comboBoxVdimmSource"
                        IsReadOnly="True"
                        Grid.Column="1"
                        Grid.Row="0"
                        Grid.ColumnSpan="2"
                        Margin="5" />

                    <Label
                        x:Name="vttSourceLabel"
                        Grid.Column="0"
                        Grid.Row="1"
                        Content="VTT Source"
                        VerticalAlignment="Center"
                        Padding="5 0" FontWeight="Normal" />

                    <ComboBox
                        x:Name="comboBoxVttSource"
                        IsReadOnly="True"
                        Grid.Column="1"
                        Grid.Row="1"
                        Grid.ColumnSpan="2"
                        Margin="5"
                        ItemsSource="{x:Null}"/>
                </Grid>
            </TabItem>
        </TabControl-->

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>

            <Button
                    x:Name="buttonSettingsRestart"
                    Grid.Column="0"
                    Content="Restart"
                    Visibility="Hidden"
                    Margin="10 10 0 10"
                    Width="70"
                    Click="ButtonSettingsRestart_Click" />

            <Button
                    x:Name="buttonSettingsApply"
                    Grid.Column="2"
                    Content="Apply"
                    Margin="10 10 0 10"
                    Style="{DynamicResource {x:Static adonisUi:Styles.AccentButton}}"
                    Width="70"
                    Click="ButtonSettingsApply_Click" />

            <Button
                    x:Name="buttonSettingsCancel"
                    Grid.Column="3"
                    Content="Close"
                    IsCancel="True"
                    Width="70"
                    Margin="10"
                    Click="ButtonSettingsCancel_Click" />
        </Grid>
    </StackPanel>
</local:ThemedAdonisWindow>