<local:ThemedAdonisWindow
    xmlns:local="clr-namespace:ZenTimings"
    x:Class="ZenTimings.Windows.UpdateProgressWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:adonisExtensions="clr-namespace:AdonisUI.Extensions;assembly=AdonisUI"
    adonisExtensions:CursorSpotlightExtension.RelativeSpotlightSize="0"
    mc:Ignorable="d"
    Title="ZenTimings Update"
    Width="400"
    SizeToContent="Height"
    WindowStartupLocation="CenterScreen"
    ResizeMode="NoResize"
    BorderThickness="1"
    UseLayoutRounding="True"
    Style="{DynamicResource WindowStyles}">
    <StackPanel Margin="20">
        <TextBlock Name="StatusText"
                   Text="Preparing update..."
                   TextWrapping="Wrap"
                   Margin="0,0,0,12"
                   FontSize="13" />

        <ProgressBar Name="ProgressBar"
                     Height="20"
                     Minimum="0"
                     Maximum="100"
                     Value="0"
                     Margin="0,0,0,8" />

        <TextBlock Name="ProgressDetail"
                   Text=""
                   Foreground="Gray"
                   FontSize="11"
                   Margin="0,0,0,12" />

        <Button Name="CancelButton"
                Content="Cancel"
                HorizontalAlignment="Right"
                MinWidth="80"
                Click="CancelButton_Click" />
    </StackPanel>
</local:ThemedAdonisWindow>
